rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────

    // التحقق من تسجيل دخول الأدمن
    function isAdmin() {
      return request.auth != null;
    }

    // التحقق من تسجيل الدخول العام
    function isAuthenticated() {
      return request.auth != null;
    }

    // التحقق من صاحب الحساب
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── 1. المنتجات (Products) ────────────────────────────────────────
    match /products/{productId} {
      // أي زائر يمكنه قراءة المنتجات
      allow read: if true;
      
      // التعديل والإضافة والحذف فقط للأدمن المسجل
      allow create, update, delete: if isAdmin();
    }

    // ─── 2. الأقسام (Categories) ────────────────────────────────────────
    match /categories/{categoryId} {
      // قراءة الأقسام متاحة للجميع
      allow read: if true;
      
      // الأدمن فقط يمكنه إضافة أو تغيير الأقسام
      allow create, update, delete: if isAdmin();
    }

    // ─── 3. إعدادات الموقع (Site Settings & CMS) ─────────────────────────
    match /site_settings/{settingId} {
      // قراءة الإعدادات متاحة لجميع الزوار (الهيرو، بيانات الشحن، روابط التواصل)
      allow read: if true;
      
      // الأدمن فقط يمكنه حفظ أو تعديل إعدادات الموقع
      allow create, update, delete: if isAdmin();
    }

    // ─── 4. الطلبات (Orders) ───────────────────────────────────────────
    match /orders/{orderId} {
      // أي عميل يمكنه إنشاء طلب جديد بشرط أن تكون حالته الإبتدائية pending
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.items is list
                    && request.resource.data.customerName is string
                    && (request.resource.data.phone is string || request.resource.data.customerPhone is string);

      // قراءة الطلبات، تغيير حالتها (مكتمل، ملغي)، أو حذفها محصورة على الأدمن فقط
      allow read, update, delete: if isAdmin();
    }

    // ─── 5. رسائل الشكاوى والتواصل (Contact Messages) ────────────────────
    match /contact_messages/{messageId} {
      // إرسال رسالة جديد متاح للجميع
      allow create: if request.resource.data.name is string
                    && request.resource.data.message is string;

      // قراءة الرسائل وتحديدها كـ "مقروءة" أو حذفها محصورة على الأدمن فقط
      allow read, update, delete: if isAdmin();
    }

    // ─── 6. سجل أخطاء النظام (System Error Logs) ──────────────────────
    match /system_errors/{errorId} {
      // السماح بتسجيل أخطاء النظام من الجانب المباشر للعميل
      allow create: if true;

      // قراءة وحذف ومعالجة الأخطاء محصورة على الأدمن فقط
      allow read, update, delete: if isAdmin();
    }

    // ─── 7. حسابات العملاء (Users) ─────────────────────────────────────
    match /users/{userId} {
      // المستخدم يمكنه قراءة وتحديث بياناته فقط، والأدمن يمكنه الاطلاع على الجميع
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── الحماية الافتراضية لأي مجموعة أخرى غير معروفة ───────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
